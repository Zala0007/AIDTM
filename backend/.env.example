# Environment variables for Clinker DSS Backend
# Copy this to .env and customize for your environment

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_WORKERS=4

# Solver Configuration
SOLVER_NAME=gurobi
SOLVER_TIME_LIMIT=300
SOLVER_MIP_GAP=0.01
SOLVER_THREADS=4
SOLVER_LOG_OUTPUT=False

# Optimization Model Configuration
OPTIMIZATION_ENABLE_WARMSTART=True
OPTIMIZATION_PRESOLVE=2
OPTIMIZATION_FOCUS=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/clinker_dss.log

# Database (future use)
DATABASE_URL=sqlite:///./clinker_dss.db
DATABASE_ECHO=False

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Data paths
DATA_DIR=./data
SAMPLE_DATA_DIR=./data/samples
EXPORT_DIR=./exports

# Features
FEATURE_CONSOLIDATION_ANALYSIS=True
FEATURE_UNCERTAINTY_ANALYSIS=True
FEATURE_SCENARIO_COMPARISON=True

# Gurobi License (if using commercial version)
# GUROBI_HOME=/path/to/gurobi/linux64
# GRB_LICENSE_FILE=/path/to/gurobi.lic
